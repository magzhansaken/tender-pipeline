# ────────────────────────────────────────────────────────────────
#  TenderView — шаблон переменных окружения
#  Скопируй в .env и заполни реальными значениями.
#  ВНИМАНИЕ: настоящий .env НЕ коммитится в git (см. .gitignore).
# ────────────────────────────────────────────────────────────────

# База данных PostgreSQL
POSTGRES_USER=tender
POSTGRES_PASSWORD=ЗАМЕНИ_НА_СВОЙ_ПАРОЛЬ
POSTGRES_DB=tender

# Домен витрины (для Caddy / TLS)
DOMAIN=tenderfinder.example.io

# Ollama Cloud (нормализация ТЗ и верификация товаров)
OLLAMA_API_KEY=ЗАМЕНИ_НА_КЛЮЧ_OLLAMA

# Пароль входа в админ-панель (/admin)
ADMIN_PASSWORD=ЗАМЕНИ_НА_ПАРОЛЬ_АДМИНКИ

# Реестр сертификатов соответствия (внешний API). Базовый URL без слэша на конце.
# Если задан — на карточке лота появляется проверка сертификатов по товару.
CERT_API_URL=
# Ключ, если API его требует (Bearer). Иначе оставь пустым.
CERT_API_KEY=
